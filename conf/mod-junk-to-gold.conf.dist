[worldserver]

########################################
# Mod Junk To Gold Configuration
########################################
#
#	 ModJunkToGold.Enable
#        Description: Enable Junk To Gold Mod.
#        Default:     0 - Disabled
#                     1 - Enabled
#
#	 ModJunkToGold.EnableForRealPlayer
#        Description: Enable Junk To Gold Mod. for real player
#        Default:     0 - Disabled
#                     1 - Enabled
#
#	 ModJunkToGold.EnableForPlayerbot
#        Description: Enable Junk To Gold Mod. for playerbot
#        Default:     0 - Disabled
#                     1 - Enabled

ModJunkToGold.Enable = 1
ModJunkToGold.EnableForRealPlayer = 1
ModJunkToGold.EnableForPlayerbot = 1
